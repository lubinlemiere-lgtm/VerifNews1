# ── Base de donnees ────────────────────────────────────
# Local (dev) :
DATABASE_URL=postgresql+asyncpg://verifnews:verifnews@localhost:5432/verifnews
# Supabase (prod) :
# DATABASE_URL=postgresql+asyncpg://postgres.[ref]:[password]@aws-1-eu-west-1.pooler.supabase.com:6543/postgres

# ── JWT Authentication ────────────────────────────────
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30

# ── API Keys ──────────────────────────────────────────
NEWSAPI_KEY=
TMDB_API_KEY=

# ── Pipeline ──────────────────────────────────────────
TTS_CACHE_DIR=./audio_cache
EMBEDDING_MODEL=all-MiniLM-L6-v2
VERIFICATION_THRESHOLD=0.75
DEDUP_THRESHOLD=0.15
MIN_VERIFICATION_SOURCES=2
PIPELINE_INTERVAL_MINUTES=30

# ── SMTP (emails de verification, reset password) ────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_NAME=VerifNews
SMTP_FROM_EMAIL=your-email@gmail.com

# ── Frontend URL ──────────────────────────────────────
APP_FRONTEND_URL=https://verifnews.app
